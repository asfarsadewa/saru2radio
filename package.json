{
  "name": "saru2radio",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bun run build && tsx server/index.ts",
    "start": "tsx server/index.ts",
    "prepare:radio": "tsx server/prepare-cli.ts",
    "setup:radio-sound": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/setup-radio-sound.ps1",
    "check": "svelte-check --tsconfig ./tsconfig.json && tsc -p tsconfig.server.json --noEmit",
    "build": "vite build",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test": "bun run check && bun run test:unit && bun run build && bun run test:e2e"
  },
  "dependencies": {
    "@breezystack/lamejs": "^1.2.7",
    "@lucide/svelte": "^1.25.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "music-metadata": "^11.14.0",
    "openai": "^6.48.0",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/ws": "^8.18.1",
    "svelte": "^5.56.6",
    "svelte-check": "^4.7.3",
    "tsx": "^4.23.1",
    "typescript": "6.0.3",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
