{
  "name": "saru2radio",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "npm run build && tsx server/index.ts",
    "start": "tsx server/index.ts",
    "prepare:radio": "tsx server/prepare-cli.ts",
    "setup:radio-sound": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/setup-radio-sound.ps1",
    "check": "svelte-check --tsconfig ./tsconfig.json && tsc -p tsconfig.server.json --noEmit",
    "build": "vite build",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test": "npm run check && npm run test:unit && npm run build && npm run test:e2e"
  },
  "dependencies": {
    "@breezystack/lamejs": "^1.2.7",
    "@lucide/svelte": "^1.16.0",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "music-metadata": "^11.12.3",
    "openai": "^6.39.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/express": "^5.0.5",
    "@types/node": "^22.19.0",
    "@types/ws": "^8.18.1",
    "svelte": "^5.55.2",
    "svelte-check": "^4.4.6",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.16",
    "vitest": "^4.1.3"
  }
}
